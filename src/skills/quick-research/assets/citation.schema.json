{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pionless-matrix.example/schemas/citation.json",
  "title": "Citation",
  "description": "Structured citation emitted by the quick-research skill when the host needs machine-readable references.",
  "type": "object",
  "required": ["id", "title", "url", "source_tier"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier referenced from the report body, e.g. '1' for [^1]."
    },
    "title": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "publisher": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "url": { "type": "string", "format": "uri" },
    "source_tier": {
      "enum": ["primary", "authoritative_secondary", "weak"]
    },
    "accessed": { "type": "string", "format": "date" },
    "notes": {
      "type": "string",
      "description": "Optional analyst note, e.g. 'press release; multiple outlets republished'."
    }
  }
}
